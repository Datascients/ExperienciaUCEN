# LLM
OPENAI_API_KEY=               # GPT-4o + embeddings

# Vector DB
PINECONE_API_KEY=
PINECONE_INDEX_NAME=desercion-docs

# Base de datos
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scoring ML externo
ML_SCORING_ENDPOINT=          # POST /score → { estudiante_id, features }

# App
ENVIRONMENT=production
PORT=8080

# Railway — backend deploy (railway.app → Account Settings → Tokens)
RAILWAY_TOKEN=
RAILWAY_SERVICE_URL=          # ej: https://consultorestudiante.up.railway.app

# Netlify — frontend deploy (app.netlify.com → User Settings → Personal access tokens)
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=               # app.netlify.com → Site Settings → Site information → Site ID
